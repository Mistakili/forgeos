# ── ForgeOS Configuration ──────────────────────────────────────────

# Environment: development | production
FORGE_ENV=development
FORGE_HOST=0.0.0.0
FORGE_PORT=8000
# FORGE_CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# Reasoning: auto (use any configured key) | mock (force offline)
FORGE_REASONING_MODE=auto
# Pin a provider: openai | anthropic | qwen | groq | openrouter | google | ollama
# FORGE_DEFAULT_PROVIDER=openai

# ── Bring Your Own Model (BYOM) — add ANY one to enable live reasoning ──

# OpenAI / ChatGPT
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Alibaba Qwen (DashScope)
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Groq (fast, cheap)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter (multi-model gateway)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Ollama (local / private)
# OLLAMA_ENABLED=true
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2